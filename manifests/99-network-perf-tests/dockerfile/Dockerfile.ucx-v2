# Multi-stage build with fixed UCX compatibility
FROM nvcr.io/nvidia/cuda:12.3.1-devel-ubuntu22.04 AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y     git     make     build-essential     autoconf     automake     libtool     pkg-config     libibverbs-dev     librdmacm-dev     libibumad-dev     libpci-dev     rdma-core     libnuma-dev     wget     && rm -rf /var/lib/apt/lists/*

# Build perftest with CUDA support
RUN git clone https://github.com/linux-rdma/perftest.git /tmp/perftest     && cd /tmp/perftest     && ./autogen.sh     && CUDA_H_PATH=/usr/local/cuda/include        CFLAGS="-O3"        CXXFLAGS="-O3"        ./configure --prefix=/usr --enable-cuda --with-cuda=/usr/local/cuda     && make -j$(nproc)     && make install DESTDIR=/perftest-install

# Build UCX from git (latest stable) for better compatibility
RUN cd /tmp     && git clone --depth 1 --branch v1.18.x https://github.com/openucx/ucx.git     && cd ucx     && ./autogen.sh     && ./contrib/configure-release        --prefix=/usr/local        --with-cuda=/usr/local/cuda        --with-rdmacm        --with-verbs        --with-mlx5-dv        --enable-optimizations        --disable-logging        --disable-debug        --disable-assertions        --disable-params-check     && make -j$(nproc)     && make install DESTDIR=/ucx-install

# Build GDRCopy
RUN git clone https://github.com/NVIDIA/gdrcopy.git /tmp/gdrcopy     && cd /tmp/gdrcopy     && make lib exes     && make DESTDIR=/gdrcopy-install install

# Final stage
FROM nvcr.io/nvidia/pytorch:24.01-py3

# Install runtime dependencies
RUN apt-get update && apt-get install -y     infiniband-diags     libibverbs1     librdmacm1     libibumad3     libpci3     rdma-core     libnuma1     iproute2     iputils-ping     net-tools     ethtool     jq     bc     numactl     pciutils     vim     htop     curl     wget     iperf3     sqlite3     && rm -rf /var/lib/apt/lists/*

# Copy perftest binaries
COPY --from=builder /perftest-install/usr/bin/* /usr/bin/

# Copy UCX to /usr/local (avoid conflicts with base image)
COPY --from=builder /ucx-install/usr/local /usr/local


# Copy GDRCopy
COPY --from=builder /gdrcopy-install/usr/local/lib/* /usr/local/lib/
COPY --from=builder /gdrcopy-install/usr/local/bin/* /usr/local/bin/

# Update library cache and set LD_LIBRARY_PATH to prioritize our UCX
RUN ldconfig
ENV LD_LIBRARY_PATH=/usr/local/lib:$LD_LIBRARY_PATH

# Install Python packages
RUN pip install --no-cache-dir pandas matplotlib seaborn

# Build NCCL tests
RUN git clone https://github.com/NVIDIA/nccl-tests.git /opt/nccl-tests     && cd /opt/nccl-tests     && make MPI=0 CUDA_HOME=/usr/local/cuda NCCL_HOME=/usr/local/cuda          NVCC_GENCODE="         -gencode=arch=compute_70,code=sm_70          -gencode=arch=compute_75,code=sm_75          -gencode=arch=compute_80,code=sm_80          -gencode=arch=compute_86,code=sm_86          -gencode=arch=compute_89,code=sm_89          -gencode=arch=compute_90,code=sm_90"     && rm -rf .git     && chmod +x build/*_perf

# Create detection script
RUN printf '#!/bin/bash\necho "==========================================="\necho "perftest CUDA Support"\nib_write_bw --version 2>&1 | head -1\nldd /usr/bin/ib_write_bw | grep -q cuda && echo "✓ CUDA support" || echo "✗ No CUDA (but may load dynamically)"\necho ""\necho "UCX Support"\nif command -v ucx_info &> /dev/null; then\n    ucx_info -v 2>&1 | head -3\n    command -v ucx_perftest && echo "✓ ucx_perftest found" || echo "✗ ucx_perftest not found"\nelse\n    echo "✗ ucx_info not found"\nfi\necho "==========================================="\n' > /usr/local/bin/detect-gpu.sh && chmod +x /usr/local/bin/detect-gpu.sh

RUN mkdir -p /results

WORKDIR /opt/nccl-tests

CMD ["/bin/bash", "-c", "/usr/local/bin/detect-gpu.sh && sleep infinity"]
